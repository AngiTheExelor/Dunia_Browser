<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DUNIA Browser</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #e8a020; --gold-light: #f5c060; --gold-dim: rgba(232,160,32,0.15);
    --dark: #080a0f; --surface: #0f1117; --surface2: #161a24;
    --text: #eee8dc; --muted: rgba(238,232,220,0.48);
    --accent: #2dce6c; --accent-dim: rgba(45,206,108,0.12);
    --border: rgba(255,255,255,0.07); --border-gold: rgba(232,160,32,0.25);
    --radius: 14px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--dark); color:var(--text); font-family:'Outfit',sans-serif; font-weight:300; overflow-x:hidden; line-height:1.6; }
  body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events:none; z-index:9999; }

  /* MULTILANG — CSS driven */
  [data-lang] { display:none; }
  html[lang="fr"]       [data-lang="fr"]       { display:inline; }
  html[lang="en"]       [data-lang="en"]       { display:inline; }
  html[lang="ar"]       [data-lang="ar"]       { display:inline; }
  html[lang="moore"]    [data-lang="moore"]    { display:inline; }
  html[lang="dioula"]   [data-lang="dioula"]   { display:inline; }
  html[lang="fulfulde"] [data-lang="fulfulde"] { display:inline; }
  html[lang="songhay"]  [data-lang="songhay"]  { display:inline; }
  html[lang="gourma"]   [data-lang="gourma"]   { display:inline; }
  html[lang="bm"]       [data-lang="bm"]       { display:inline; }
  html[lang="ha"]       [data-lang="ha"]       { display:inline; }
  html[lang="wo"]       [data-lang="wo"]       { display:inline; }
  html[lang="sw"]       [data-lang="sw"]       { display:inline; }
  html[lang="yo"]       [data-lang="yo"]       { display:inline; }
  html[lang="am"]       [data-lang="am"]       { display:inline; }
  html[lang="om"]       [data-lang="om"]       { display:inline; }
  html[lang="ig"]       [data-lang="ig"]       { display:inline; }
  html[lang="so"]       [data-lang="so"]       { display:inline; }
  html[lang="mg"]       [data-lang="mg"]       { display:inline; }
  html[lang="zu"]       [data-lang="zu"]       { display:inline; }
  /* Default = fr */
  html:not([lang]) [data-lang="fr"],
  html[lang="fr"]  [data-lang="fr"] { display:inline; }

  /* RTL for Arabic */
  html[lang="ar"] { direction:rtl; }

  /* NAV */
  nav { display:flex; align-items:center; justify-content:space-between; padding:18px clamp(16px,4vw,64px); border-bottom:1px solid var(--border); position:sticky; top:0; background:rgba(8,10,15,0.9); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px); z-index:100; flex-wrap:wrap; gap:12px; }
  .logo { display:flex; align-items:center; gap:10px; text-decoration:none; }
  .logo-icon { width:36px; height:36px; background:linear-gradient(135deg,#c07a10,#f0b040); border-radius:9px; display:grid; place-items:center; font-size:19px; flex-shrink:0; box-shadow:0 4px 14px rgba(232,160,32,0.3); }
  .logo-text { font-family:'Cormorant Garamond',serif; font-size:21px; font-weight:700; color:var(--text); letter-spacing:0.02em; }
  .logo-text span { color:var(--gold); }

  /* LANG BAR */
  .lang-wrapper { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
  .lang-label { font-size:10px; letter-spacing:0.15em; text-transform:uppercase; color:var(--muted); }
  .lang-bar { display:flex; flex-wrap:wrap; gap:4px; max-width:min(700px, 70vw); }
  .lang-btn { background:transparent; border:1px solid rgba(255,255,255,0.1); border-radius:100px; color:var(--muted); font-family:'Outfit',sans-serif; font-size:11px; font-weight:400; padding:3px 10px; cursor:pointer; transition:all .18s ease; white-space:nowrap; line-height:1.5; }
  .lang-btn:hover { border-color:var(--gold); color:var(--gold); background:var(--gold-dim); }
  .lang-btn.active { border-color:var(--gold); color:var(--gold); background:var(--gold-dim); font-weight:500; }

  /* HERO */
  .hero { min-height:95vh; display:flex; flex-direction:column; padding:0 clamp(16px,5vw,72px); position:relative; overflow:hidden; }
  .hero::before { content:''; position:absolute; top:-120px; right:-180px; width:680px; height:680px; background:radial-gradient(circle,rgba(232,160,32,0.07) 0%,transparent 65%); pointer-events:none; }
  .hero::after { content:''; position:absolute; bottom:-80px; left:-120px; width:500px; height:500px; background:radial-gradient(circle,rgba(45,206,108,0.05) 0%,transparent 65%); pointer-events:none; }
  .hero-center { flex:1; display:flex; flex-direction:column; justify-content:center; padding:72px 0 56px; max-width:820px; position:relative; z-index:1; }
  .eyebrow { font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--gold); margin-bottom:26px; opacity:0; animation:fadeUp .7s .05s forwards; display:flex; align-items:center; gap:10px; }
  .eyebrow::before { content:''; display:inline-block; width:28px; height:1px; background:var(--gold); opacity:0.6; }
  h1 { font-family:'Cormorant Garamond',serif; font-size:clamp(48px,7.5vw,100px); font-weight:700; line-height:1.02; letter-spacing:-0.02em; margin-bottom:30px; opacity:0; animation:fadeUp .7s .18s forwards; }
  h1 em { font-style:italic; color:var(--gold); }
  .subtitle { font-size:clamp(14px,1.8vw,17px); color:var(--muted); line-height:1.75; max-width:560px; margin-bottom:44px; opacity:0; animation:fadeUp .7s .3s forwards; }
  .badges { display:flex; flex-wrap:wrap; gap:9px; opacity:0; animation:fadeUp .7s .44s forwards; }
  .badge { display:flex; align-items:center; gap:8px; padding:7px 16px; border:1px solid var(--border); border-radius:100px; font-size:13px; color:var(--muted); background:rgba(255,255,255,0.025); transition:all .2s; }
  .badge:hover { border-color:var(--border-gold); color:var(--text); background:var(--gold-dim); }
  .hero-bottom { padding:26px 0; border-top:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; position:relative; z-index:1; }
  .author { font-size:13px; color:var(--muted); }
  .author strong { color:var(--text); font-weight:500; }
  .version-tag { font-size:11px; padding:5px 14px; border-radius:100px; background:var(--accent-dim); border:1px solid rgba(45,206,108,0.28); color:var(--accent); font-weight:500; letter-spacing:0.05em; }

  /* SECTIONS */
  .section { padding:clamp(56px,8vw,110px) clamp(16px,5vw,72px); border-top:1px solid var(--border); }
  .section-header { display:flex; align-items:baseline; gap:16px; margin-bottom:48px; }
  .section-label { font-size:11px; letter-spacing:0.22em; text-transform:uppercase; color:var(--gold); white-space:nowrap; }
  .section-line { flex:1; height:1px; background:var(--border); max-width:200px; }

  /* FEATURES */
  .features-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:1px; background:var(--border); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
  .feature { background:var(--surface); padding:34px 30px; transition:background .22s; position:relative; }
  .feature::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,transparent,var(--gold-dim),transparent); opacity:0; transition:opacity .22s; }
  .feature:hover { background:var(--surface2); }
  .feature:hover::before { opacity:1; }
  .feature-icon { font-size:28px; margin-bottom:16px; display:block; line-height:1; }
  .feature-title { font-family:'Cormorant Garamond',serif; font-size:19px; font-weight:600; margin-bottom:9px; color:var(--text); }
  .feature-desc { font-size:13px; color:var(--muted); line-height:1.7; }

  /* GOOGLE */
  .google-section { background:var(--surface); border-top:1px solid var(--border); padding:clamp(56px,8vw,110px) clamp(16px,5vw,72px); }
  .google-card { max-width:640px; margin:0 auto; text-align:center; }
  .google-logo { display:flex; align-items:center; justify-content:center; gap:8px; margin-bottom:32px; }
  .g-dot { width:13px; height:13px; border-radius:50%; animation:pulse 2.4s infinite ease-in-out; }
  .g-dot:nth-child(1){background:#4285F4;animation-delay:0s}
  .g-dot:nth-child(2){background:#EA4335;animation-delay:.2s}
  .g-dot:nth-child(3){background:#FBBC05;animation-delay:.4s}
  .g-dot:nth-child(4){background:#34A853;animation-delay:.6s}
  @keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.3);opacity:0.7}}
  .google-card h2 { font-family:'Cormorant Garamond',serif; font-size:clamp(26px,4vw,42px); font-weight:700; margin-bottom:20px; line-height:1.15; }
  .google-card p { font-size:14px; color:var(--muted); line-height:1.8; margin-bottom:12px; }
  .scopes-list { display:inline-flex; flex-direction:column; gap:10px; margin-top:22px; text-align:left; background:rgba(255,255,255,0.025); border:1px solid var(--border); border-radius:var(--radius); padding:18px 26px; }
  .scope-item { display:flex; align-items:center; gap:10px; font-size:13px; color:var(--muted); }
  .scope-item::before { content:'✓'; color:var(--accent); font-weight:700; font-size:14px; flex-shrink:0; }

  /* LANGS SHOWCASE */
  .langs-section { padding:clamp(56px,8vw,110px) clamp(16px,5vw,72px); border-top:1px solid var(--border); }
  .langs-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(170px,1fr)); gap:8px; margin-top:44px; }
  .lang-card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:15px 18px; cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:10px; }
  .lang-card:hover, .lang-card.active-card { border-color:var(--border-gold); background:var(--gold-dim); }
  .lang-card .flag { font-size:20px; flex-shrink:0; }
  .lang-card-name { font-size:13px; font-weight:500; color:var(--text); }
  .lang-card-region { font-size:11px; color:var(--muted); margin-top:1px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  /* FOOTER */
  footer { padding:26px clamp(16px,5vw,72px); border-top:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; background:var(--surface); }
  footer p { font-size:13px; color:var(--muted); }
  footer a { color:var(--gold); text-decoration:none; font-size:13px; transition:color .18s; }
  footer a:hover { color:var(--gold-light); }

  @keyframes fadeUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
  ::-webkit-scrollbar{width:6px} ::-webkit-scrollbar-track{background:var(--dark)} ::-webkit-scrollbar-thumb{background:rgba(232,160,32,0.25);border-radius:3px} ::-webkit-scrollbar-thumb:hover{background:rgba(232,160,32,0.5)}
  @media(max-width:600px){h1{font-size:44px}.lang-label{display:none}.langs-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}}
</style>
</head>
<body>

