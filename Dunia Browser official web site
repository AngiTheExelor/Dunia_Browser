<!-- HERO -->
<div class="hero">
  <div class="hero-center">
    <div class="eyebrow">
      <span data-lang="fr">Navigateur de bureau · Windows · Linux</span>
      <span data-lang="en">Desktop Browser · Windows · Linux</span>
      <span data-lang="ar">متصفح سطح المكتب · Windows · Linux</span>
      <span data-lang="moore">Ordinatɛɛr navigatɛɛr · Windows · Linux</span>
      <span data-lang="dioula">Ordinatɛri dɔnnibaga · Windows · Linux</span>
      <span data-lang="fulfulde">Nder ordinateer · Windows · Linux</span>
      <span data-lang="songhay">Ordinateer dono · Windows · Linux</span>
      <span data-lang="gourma">Ordinateur nawubu · Windows · Linux</span>
      <span data-lang="bm">Ordinatɛri dɔnnibaga · Windows · Linux</span>
      <span data-lang="ha">Na'ura ta Binciken Intanet · Windows · Linux</span>
      <span data-lang="wo">Ordinateer bi · Windows · Linux</span>
      <span data-lang="sw">Kivinjari cha Kompyuta · Windows · Linux</span>
      <span data-lang="yo">Aṣàwákiri Kọ̀mpútà · Windows · Linux</span>
