<script>
const LANGS = ["fr","en","ar","moore","dioula","fulfulde","songhay","gourma","bm","ha","wo","sw","yo","am","om","ig","so","mg","zu"];

function setLang(lang) {
  if (!LANGS.includes(lang)) lang = 'fr';
  document.documentElement.lang = lang;
  document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
  document.querySelectorAll('.lang-btn').forEach(function(b){ b.classList.toggle('active', b.dataset.lang === lang); });
  document.querySelectorAll('.lang-card').forEach(function(card){
    var m = (card.getAttribute('onclick')||'').match(/setLang\('(.+?)'\)/);
    card.classList.toggle('active-card', m && m[1] === lang);
  });
  try { localStorage.setItem('dunia_lang', lang); } catch(e) {}
}

(function(){
  var saved; try { saved = localStorage.getItem('dunia_lang'); } catch(e) {}
  var nav = (navigator.language||'').toLowerCase();
  var auto = LANGS.find(function(l){ return nav.indexOf(l)===0; }) || 'fr';
  setLang(saved || auto);
})();
</script>
